using BepInEx;
using UnityEngine;
using System.Collections.Generic;
using System.Linq;

namespace GorillaTagVRText
{
    [BepInPlugin("com.yourname.vrtext", "VR Text Display", "1.0.0")]
    public class VRTextDisplay : BaseUnityPlugin
    {
        private GameObject textObject;
        private TextMesh textMesh;
        private GameObject[] cachedLavaMonkeys;
        private float lastSearchTime = 0f;
        private float searchInterval = 1f; // Search every 1 second instead of every frame

        void Start()
        {
            CreateVRText();
        }

        void CreateVRText()
        {
            // Create a 3D TextMesh
            textObject = new GameObject("VRText");
            textMesh = textObject.AddComponent<TextMesh>();

            // Text properties
            textMesh.text = "Searching...";
            textMesh.fontSize = 40;  // Smaller for bottom display
            textMesh.characterSize = 0.08f;  // Slightly smaller
            textMesh.color = Color.red;
            textMesh.anchor = TextAnchor.MiddleCenter;
            textMesh.alignment = TextAlignment.Center;

            if (textObject.GetComponent<MeshRenderer>() == null)
            {
                textObject.AddComponent<MeshRenderer>();
            }

            textObject.layer = 0;
        }

        Camera FindVRCamera()
        {
            // Try to find VR camera first
            Camera[] cameras = FindObjectsOfType<Camera>();

            foreach (Camera cam in cameras)
            {
                // Look for cameras that might be VR cameras
                if (cam.enabled && cam.gameObject.activeInHierarchy)
                {
                    return cam;
                }
            }

            // Fallback to Camera.main
            return Camera.main;
        }

        void Update()
        {
            // Make text follow the camera and position at bottom center
            if (textObject != null)
            {
                Camera cam = FindVRCamera();
                if (cam != null)
                {
                    // Position text at bottom center of view
                    Vector3 cameraPos = cam.transform.position;
                    Vector3 cameraForward = cam.transform.forward;
                    Vector3 cameraDown = -cam.transform.up; // Downward direction

                    // Position: 2.5 units forward, 1 unit down from camera center
                    textObject.transform.position = cameraPos + cameraForward * 2.5f + cameraDown * 1f;

                    // Make text face the camera
                    textObject.transform.LookAt(cam.transform);
                    textObject.transform.Rotate(0, 180, 0);

                    // Update distance to nearest lava monkey
                    UpdateLavaMonkeyDistance(cameraPos);
                }
            }
        }

        void UpdateLavaMonkeyDistance(Vector3 playerPosition)
        {
            // Only search for lava monkeys periodically, not every frame
            if (Time.time - lastSearchTime > searchInterval)
            {
                cachedLavaMonkeys = FindLavaMonkeys();
                lastSearchTime = Time.time;
            }

            // Use cached results for distance calculations (runs every frame)
            if (cachedLavaMonkeys == null || cachedLavaMonkeys.Length == 0)
            {
                textMesh.text = "No lava monkeys";
                textMesh.color = Color.gray;
                return;
            }

            // Find the closest lava monkey from cached results
            float closestDistance = float.MaxValue;
            GameObject closestLavaMonkey = null;

            foreach (GameObject lavaMonkey in cachedLavaMonkeys)
            {
                if (lavaMonkey != null)
                {
                    float distance = Vector3.Distance(playerPosition, lavaMonkey.transform.position);
                    if (distance < closestDistance)
                    {
                        closestDistance = distance;
                        closestLavaMonkey = lavaMonkey;
                    }
                }
            }

            // Update the text display - only show meters
            if (closestLavaMonkey != null)
            {
                textMesh.text = $"{closestDistance:F1}m";

                // Change color based on distance
                if (closestDistance < 5f)
                    textMesh.color = Color.red;
                else if (closestDistance < 10f)
                    textMesh.color = Color.yellow;
                else
                    textMesh.color = Color.green;
            }
        }

        GameObject[] FindLavaMonkeys()
        {
            List<GameObject> lavaMonkeys = new List<GameObject>();

            // Simplified and faster search - only check the most likely candidates

            // Method 1: Find players by tag first (most efficient)
            try
            {
                GameObject[] players = GameObject.FindGameObjectsWithTag("Player");
                foreach (GameObject player in players)
                {
                    if (player.name.ToLower().Contains("lava"))
                        lavaMonkeys.Add(player);
                }
            }
            catch { }

            // Method 2: If no tagged players found, do a broader but limited search
            if (lavaMonkeys.Count == 0)
            {
                GameObject[] allObjects = FindObjectsOfType<GameObject>();
                foreach (GameObject obj in allObjects)
                {
                    string name = obj.name.ToLower();
                    if (name.Contains("lava") && (name.Contains("monkey") || name.Contains("player") || name.Contains("rig")))
                    {
                        lavaMonkeys.Add(obj);
                    }
                }
            }

            return lavaMonkeys.ToArray();
        }
    }
}
